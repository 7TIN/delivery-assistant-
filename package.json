{
    "name":  "delivery",
    "type":  "module",
    "private":  true,
    "scripts":  {
                    "dev":  "bun run apps/order-api/src/main.ts",
                    "dev:order-api":  "bun run apps/order-api/src/main.ts",
                    "dev:orchestrator":  "bun run apps/orchestrator/src/main.ts",
                    "dev:vendor-agent":  "bun run apps/vendor-agent/src/main.ts",
                    "dev:report-aggregator":  "bun run apps/report-aggregator/src/main.ts",
                    "dev:route-planner":  "bun run apps/route-planner/src/main.ts",
                    "dev:dispatch":  "bun run apps/dispatch/src/main.ts",
                    "dev:ops-fallback":  "bun run apps/ops-fallback/src/main.ts",
                    "typecheck":  "tsc --noEmit",
                    "smoke:test":  "powershell -ExecutionPolicy Bypass -File scripts/smoke-test.ps1 -RepositoryDriver memory",
                    "test":  "bun test",
                    "prisma":  "bunx --bun prisma",
                    "prisma:generate":  "bunx --bun prisma generate",
                    "prisma:migrate":  "bunx --bun prisma migrate dev --name init"
                },
    "devDependencies":  {
                            "@types/bun":  "latest",
                            "@types/pg":  "^8.20.0",
                            "prisma":  "^7.5.0"
                        },
    "peerDependencies":  {
                             "typescript":  "^5"
                         },
    "dependencies":  {
                         "@prisma/adapter-pg":  "^7.5.0",
                         "@prisma/client":  "^7.5.0",
                         "bullmq":  "^5.71.1",
                         "ioredis":  "^5.10.1",
                         "pg":  "^8.20.0"
                     }
}
