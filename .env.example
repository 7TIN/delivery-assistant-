# Runtime
ORDER_API_PORT=3000
QUEUE_DRIVER=in-memory

# Storage repository
# Use `memory` for local/testing, `prisma` for Postgres persistence.
REPOSITORY_DRIVER=memory
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/delivery

# OSRM routing provider
# Set false to force local estimator.
OSRM_ENABLED=true
OSRM_BASE_URL=https://router.project-osrm.org
OSRM_TIMEOUT_MS=10000`nOSRM_HEALTH_RETRIES=3`nOSRM_HEALTH_RETRY_DELAY_MS=600

# Vendor-agent confidence threshold
# Lower value accepts more automated confirmations; higher value creates more ops tickets.
VENDOR_MIN_CONFIDENCE=0.65

# BullMQ / Redis settings (used when QUEUE_DRIVER=bullmq)
REDIS_URL=redis://localhost:6379
QUEUE_PREFIX=delivery
QUEUE_MAX_ATTEMPTS=3
QUEUE_BASE_BACKOFF_MS=200
QUEUE_WORKER_CONCURRENCY=5
QUEUE_REMOVE_ON_COMPLETE_COUNT=500
QUEUE_REMOVE_ON_FAIL_COUNT=500

